---
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
const accountBaseUrl = import.meta.env.PUBLIC_ACCOUNT_URL || import.meta.env.PUBLIC_APP_URL || "http://localhost:3000";
const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://donatecrate-site.pages.dev";
const currentUrl = new URL(Astro.request.url);
const canonicalUrl = new URL(currentUrl.pathname + currentUrl.search, siteUrl).toString();
const ogImageUrl = new URL("/images/hero-doorstep.jpg", siteUrl).toString();
const iconUrl = new URL("/favicon.svg", siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={iconUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DonateCrate" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="DonateCrate orange pickup bag at a front door" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-logo">
        <img src="/images/logo-provided.png" alt="DonateCrate" />
      </a>
      <nav class="site-nav">
        <a href="/how-it-works">How It Works</a>
        <a href="/what-we-take">What We Take</a>
        <a href="/neighborhoods">Neighborhoods</a>
        <a href="/faq">FAQ</a>
      </nav>
      <div class="site-actions">
        <a class="button button--quiet" href={`${accountBaseUrl}/login?next=/app`}>Login</a>
        <a class="button" href="/signup">Create Account</a>
      </div>
      <details class="site-mobile-menu">
        <summary>Menu</summary>
        <div class="site-mobile-menu__panel">
          <nav class="site-mobile-nav">
            <a href="/how-it-works">How It Works</a>
            <a href="/what-we-take">What We Take</a>
            <a href="/neighborhoods">Neighborhoods</a>
            <a href="/faq">FAQ</a>
          </nav>
          <div class="site-mobile-actions">
            <a class="button button--quiet" href={`${accountBaseUrl}/login?next=/app`}>Login</a>
            <a class="button" href="/signup">Create Account</a>
          </div>
        </div>
      </details>
    </header>
    <slot />
    <footer class="site-footer">
      <div>
        <a href="/" class="site-logo site-logo--footer">
          <img src="/images/logo-provided.png" alt="DonateCrate" />
        </a>
        <p>Monthly donation pickup designed for neighborhoods that want a cleaner giving habit.</p>
      </div>
      <div class="site-footer__links">
        <a href="/how-it-works">How It Works</a>
        <a href="/what-we-take">Accepted Items</a>
        <a href="/neighborhoods">Neighborhoods</a>
        <a href="/faq">FAQ</a>
      </div>
      <div class="site-footer__links">
        <a href={`${accountBaseUrl}/login?next=/app`}>Customer Login</a>
        <a href="/signup">Signup</a>
      </div>
    </footer>
  </body>
</html>
