---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="What DonateCrate Accepts"
  description="See which clothing, shoes, and household textiles DonateCrate accepts for monthly pickup."
>
  <main class="simple-page">
    <a class="back-link" href="/">Back to home</a>
    <span class="eyebrow">Accepted Items</span>
    <h1>Clothing, shoes, and linens that are clean, dry, and ready to bag.</h1>
    <div class="simple-grid">
      <article>
        <h2>Clothing</h2>
        <p>T-shirts, denim, jackets, dresses, kids clothing, and seasonal apparel.</p>
      </article>
      <article>
        <h2>Shoes</h2>
        <p>Paired footwear in reusable condition. Keep pairs together when bagging.</p>
      </article>
      <article>
        <h2>Linens</h2>
        <p>Sheets, towels, blankets, and comparable home textiles that are dry and contained.</p>
      </article>
    </div>
  </main>
</SiteLayout>
