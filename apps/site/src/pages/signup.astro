---
const accountBaseUrl = import.meta.env.PUBLIC_ACCOUNT_URL || import.meta.env.PUBLIC_APP_URL || "http://localhost:3000";
const accountSignupUrl = `${accountBaseUrl.replace(/\/$/, "")}/signup`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Continue to DonateCrate signup</title>
    <meta name="description" content="Continue to DonateCrate account signup." />
  </head>
  <body style="margin:0;display:grid;min-height:100vh;place-items:center;background:#f7fafc;font-family:'Avenir Next','Segoe UI',Arial,sans-serif;color:#0f1726;">
    <main style="max-width:34rem;padding:2rem;text-align:center;">
      <p style="margin:0 0 0.75rem;font-size:0.78rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#e14f00;">DonateCrate</p>
      <h1 style="margin:0;font-size:clamp(2rem,5vw,3rem);line-height:1.02;">Taking you to secure signup</h1>
      <p style="margin:1rem 0 0;color:#5d697c;line-height:1.7;">
        We are forwarding you to account setup so we can verify the address and continue with the right flow.
      </p>
      <p style="margin:1.5rem 0 0;">
        <a id="continue-link" href={accountSignupUrl} style="display:inline-flex;align-items:center;justify-content:center;min-height:3rem;padding:0.85rem 1.3rem;border-radius:999px;background:#ff6b00;color:#fff;font-weight:700;text-decoration:none;">
          Continue to signup
        </a>
      </p>
    </main>
    <script is:inline define:vars={{ accountSignupUrl }}>
      const target = `${accountSignupUrl}${window.location.search || ""}`;
      const link = document.getElementById("continue-link");
      if (link) link.setAttribute("href", target);
      window.location.replace(target);
    </script>
  </body>
</html>
