---
import SiteLayout from "../layouts/SiteLayout.astro";
import { ServiceCheckIsland } from "../components/marketing/ServiceCheckIsland";

const accountBaseUrl = import.meta.env.PUBLIC_ACCOUNT_URL || import.meta.env.PUBLIC_APP_URL || "https://app.donatecrate.com";
const apiBaseUrl = import.meta.env.PUBLIC_APP_URL || "https://app.donatecrate.com";
---

<SiteLayout
  title="DonateCrate | Monthly Donation Pickup"
  description="Monthly doorstep pickup for clothing, shoes, linens, and bag-friendly household goods. Check your address and see if DonateCrate is live in your neighborhood."
>
  <main>
    <section class="hero">
      <div class="hero__backdrop"></div>
      <div class="hero__media">
        <picture>
          <source
            srcset="/images/hero-doorstep-800.webp 800w, /images/hero-doorstep-1200.webp 1200w"
            sizes="(max-width: 900px) 100vw, 42vw"
            type="image/webp"
          />
          <source
            srcset="/images/hero-doorstep-800.jpg 800w, /images/hero-doorstep-1200.jpg 1200w"
            sizes="(max-width: 900px) 100vw, 42vw"
            type="image/jpeg"
          />
          <img
            src="/images/hero-doorstep-1200.jpg"
            alt="DonateCrate bag on a doorstep"
            width="1200"
            height="900"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </picture>
        <div class="hero__glow hero__glow--one"></div>
        <div class="hero__glow hero__glow--two"></div>
      </div>
      <div class="hero__content">
        <div class="hero__copy">
          <span class="eyebrow">Knoxville Launch</span>
          <h1>Turn overflowing closets into a simple monthly habit.</h1>
          <p class="hero__lede">
            DonateCrate makes it easy to clear out clothing, shoes, and household items you no longer need.
            If it fits in the bag, we are happy to take it. Check your address, join in minutes, and leave your pickup out on service day.
          </p>
          <div class="hero__stats">
            <div>
              <strong>Easy to keep up with</strong>
              <span>One clear pickup rhythm instead of another errand on your list.</span>
            </div>
            <div>
              <strong>Built around your address</strong>
              <span>Instantly see whether you can join now or when your area is next.</span>
            </div>
            <div>
              <strong>Reliable by design</strong>
              <span>Neighborhood-by-neighborhood pickup keeps the experience dependable.</span>
            </div>
          </div>
        </div>

        <div class="hero__panel">
          <ServiceCheckIsland client:load apiBaseUrl={apiBaseUrl} accountBaseUrl={accountBaseUrl} />
        </div>
      </div>
    </section>

    <section class="section section--market">
      <div class="section-heading">
        <span class="eyebrow">How It Works</span>
        <h2>Three steps, then pickup takes care of itself every month.</h2>
      </div>
      <div class="market-grid">
        <article>
          <span>Step 1</span>
          <strong>Check your address. Get an answer in seconds.</strong>
          <p>Enter your address and we tell you right away whether service is live in your neighborhood or opening soon.</p>
        </article>
        <article>
          <span>Step 2</span>
          <strong>Sign up once. Pickup runs every month.</strong>
          <p>Create your account and you're set. We send reminders before each cycle so you always know when to leave the bag out.</p>
        </article>
        <article>
          <span>Step 3</span>
          <strong>Fill the bag. Leave it out. Done.</strong>
          <p>Pack what no longer serves you, set it on the doorstep on service day, and we handle everything from there.</p>
        </article>
      </div>
    </section>

    <section class="section section--dark">
      <div class="section-heading">
        <span class="eyebrow">The Mission</span>
        <h2>Making it easier to donate than to toss.</h2>
      </div>
      <div class="timeline-grid">
        <article>
          <span>01</span>
          <h3>No trip to the donation center</h3>
          <p>The pile in your trunk never makes it. Doorstep pickup removes the biggest friction point so donating actually happens, every month.</p>
        </article>
        <article>
          <span>02</span>
          <h3>A habit you can actually keep</h3>
          <p>Monthly cycles with automatic reminders turn one-off intentions into a reliable routine. The bag is always ready. Service day always comes.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Built to stay dependable</h3>
          <p>Neighborhood-by-neighborhood rollout means we only expand where we can deliver consistently — no stretched-thin service areas.</p>
        </article>
      </div>
    </section>

    <section class="section section--gallery">
      <div class="section-heading">
        <span class="eyebrow">Accepted Items</span>
        <h2>If it fits in the bag, we're happy to take it.</h2>
      </div>
      <div class="gallery-grid">
        <article>
          <h3>Clothing</h3>
          <p>Everyday clothes, jackets, kids items, and other clean, dry apparel ready to bag up.</p>
        </article>
        <article>
          <h3>Shoes</h3>
          <p>Paired shoes and wearable footwear that can be packed neatly with the rest of your pickup.</p>
        </article>
        <article>
          <h3>Household items</h3>
          <p>Small household goods are welcome too — as long as they fit in the bag or can be left in a marked crate or box if fragile.</p>
        </article>
      </div>
    </section>

    <section class="section section--cta">
      <div>
        <span class="eyebrow">Ready to start?</span>
        <h2>Check your address and see if DonateCrate is live in your neighborhood.</h2>
      </div>
      <div class="cta-card">
        <p>
          If your address isn't active yet, join the waitlist. It helps us decide where to open next and gets you notified the moment your area goes live.
        </p>
        <div class="cta-card__actions">
          <a class="button" href="/">Check My Address</a>
          <a class="button button--quiet" href="/faq">See common questions</a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
