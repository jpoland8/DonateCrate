---
import SiteLayout from "../layouts/SiteLayout.astro";
import { WaitlistFormIsland } from "../components/marketing/WaitlistFormIsland";
const apiBaseUrl = import.meta.env.PUBLIC_APP_URL || "https://app.donatecrate.com";
---

<SiteLayout
  title="DonateCrate Waitlist"
  description="Join the DonateCrate waitlist and help shape where monthly pickup opens next."
>
  <main class="simple-page">
    <a class="back-link" href="/">Back to home</a>
    <span class="eyebrow">Pending Zone</span>
    <h1>Join the waitlist and help bring pickup to your neighborhood sooner.</h1>
    <p class="simple-page__lede">
      We expand neighborhood by neighborhood so pickup stays dependable. If your address is not active yet, add it
      here and we will let you know when your area is ready.
    </p>
    <div class="waitlist-shell">
      <div class="waitlist-copy">
        <h2>What happens next</h2>
        <ul>
          <li>Your address is saved so we can see where interest is building.</li>
          <li>Waitlist demand helps decide which neighborhood should open next.</li>
          <li>You hear from us when your address becomes eligible for signup.</li>
        </ul>
      </div>
      <div class="waitlist-card">
        <WaitlistFormIsland client:load apiBaseUrl={apiBaseUrl} />
      </div>
    </div>
  </main>
</SiteLayout>
